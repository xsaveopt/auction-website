{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Business Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Active Auctions",
      "type": "stat",
      "gridPos": { "h": 3, "w": 5, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "app_active_auctions",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Online Users",
      "type": "stat",
      "gridPos": { "h": 3, "w": 5, "x": 5, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "blue", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "app_online_users",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Bids",
      "type": "stat",
      "gridPos": { "h": 3, "w": 5, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "app_total_bids",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Winning Bid Total",
      "type": "stat",
      "gridPos": { "h": 3, "w": 5, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "app_winning_bid_total",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Unanswered Questions",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "app_questions_unanswered",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Recent User Signups",
      "type": "table",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "sortBy": [{ "displayName": "Signed Up", "desc": true }]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Signed Up" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsSystem" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {
              "username": "Username",
              "Value": "Signed Up"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "app_user_signup_timestamp",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Bids on Active Listings",
      "type": "table",
      "gridPos": { "h": 7, "w": 16, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "sortBy": [{ "displayName": "Last Updated", "desc": true }]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Amount" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last Updated" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsSystem" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "quantity": true },
            "renameByName": {
              "auction": "Auction",
              "username": "Bidder",
              "amount": "Amount",
              "Value": "Last Updated"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "app_auction_bid_info",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Application Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 3, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(app_http_requests_total[1m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 3, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(app_http_requests_total{status_code=~\"[45]..\"}[5m])) / sum(rate(app_http_requests_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "p95 Latency",
      "type": "stat",
      "gridPos": { "h": 3, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "options": { "graphMode": "area" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Traffic & Errors",
      "description": "Request throughput with error overlay — quickly spot if errors correlate with traffic spikes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(app_http_requests_total{status_code=~\"2..\"}[1m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(app_http_requests_total{status_code=~\"3..\"}[1m]))",
          "legendFormat": "3xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(app_http_requests_total{status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "C"
        },
        {
          "expr": "sum(rate(app_http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Latency Distribution",
      "description": "Heatmap of request durations — reveals latency patterns that percentile lines miss",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges", "mode": "scheme" },
        "cellGap": 1
      },
      "targets": [
        {
          "expr": "sum(increase(app_http_request_duration_seconds_bucket[1m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Route Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": true,
      "panels": [
        {
          "title": "Slowest Routes (p95)",
          "description": "Top 10 routes by p95 latency — find your bottlenecks at a glance",
          "type": "bargauge",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 0.25 },
                  { "color": "orange", "value": 0.5 },
                  { "color": "red", "value": 1.0 }
                ]
              }
            }
          },
          "options": {
            "orientation": "horizontal",
            "displayMode": "gradient",
            "reduceOptions": { "calcs": ["lastNotNull"] }
          },
          "targets": [
            {
              "expr": "topk(10, histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (route, le)))",
              "legendFormat": "{{route}}",
              "refId": "A"
            }
          ]
        },
        {
          "title": "Route Detail",
          "description": "Per-route throughput, latency percentiles, and error rates",
          "type": "table",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "options": {
            "sortBy": [{ "displayName": "p95", "desc": true }]
          },
          "fieldConfig": {
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Req/s" },
                "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 2 }]
              },
              {
                "matcher": { "id": "byName", "options": "p50" },
                "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }]
              },
              {
                "matcher": { "id": "byName", "options": "p95" },
                "properties": [
                  { "id": "unit", "value": "s" },
                  { "id": "decimals", "value": 3 },
                  { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.25 }, { "color": "red", "value": 1.0 }] } },
                  { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "Error %" },
                "properties": [
                  { "id": "unit", "value": "percentunit" },
                  { "id": "decimals", "value": 1 },
                  { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } },
                  { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
                ]
              }
            ]
          },
          "transformations": [
            { "id": "merge", "options": {} },
            {
              "id": "organize",
              "options": {
                "excludeByName": { "Time": true },
                "renameByName": {
                  "Value #A": "Req/s",
                  "Value #B": "p50",
                  "Value #C": "p95",
                  "Value #D": "Error %"
                }
              }
            }
          ],
          "targets": [
            {
              "expr": "sum(rate(app_http_requests_total[5m])) by (route)",
              "legendFormat": "",
              "refId": "A",
              "format": "table",
              "instant": true
            },
            {
              "expr": "histogram_quantile(0.50, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (route, le))",
              "legendFormat": "",
              "refId": "B",
              "format": "table",
              "instant": true
            },
            {
              "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (route, le))",
              "legendFormat": "",
              "refId": "C",
              "format": "table",
              "instant": true
            },
            {
              "expr": "sum(rate(app_http_requests_total{status_code=~\"[45]..\"}[5m])) by (route) / sum(rate(app_http_requests_total[5m])) by (route)",
              "legendFormat": "",
              "refId": "D",
              "format": "table",
              "instant": true
            }
          ]
        }
      ]
    },
    {
      "title": "Caddy Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": true,
      "panels": [
        {
          "title": "Caddy Request Duration (p50 / p95)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
            }
          },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, sum(rate(caddy_http_request_duration_seconds_bucket[5m])) by (le))",
              "legendFormat": "p50",
              "refId": "A"
            },
            {
              "expr": "histogram_quantile(0.95, sum(rate(caddy_http_request_duration_seconds_bucket[5m])) by (le))",
              "legendFormat": "p95",
              "refId": "B"
            }
          ]
        },
        {
          "title": "Caddy Memory & Goroutines",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "bytes",
              "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Goroutines" },
                "properties": [
                  { "id": "unit", "value": "short" },
                  { "id": "custom.axisPlacement", "value": "right" }
                ]
              }
            ]
          },
          "targets": [
            {
              "expr": "process_resident_memory_bytes{job=\"caddy\"}",
              "legendFormat": "Resident memory",
              "refId": "A"
            },
            {
              "expr": "go_memstats_heap_inuse_bytes{job=\"caddy\"}",
              "legendFormat": "Heap in use",
              "refId": "B"
            },
            {
              "expr": "go_goroutines{job=\"caddy\"}",
              "legendFormat": "Goroutines",
              "refId": "C"
            }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["auction"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Auction App",
  "uid": "auction-app"
}
