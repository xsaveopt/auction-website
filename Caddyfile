{
	{$CADDY_GLOBAL_OPTIONS}

	admin 0.0.0.0:2019

	metrics

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}

	servers
}

{$SERVER_NAME:localhost} {
	log access {
		output file /data/logs/caddy-access.log {
			roll_disabled
		}
		format console
	}

	log debug {
		output file /data/logs/caddy-debug.log {
			roll_disabled
		}
		format json
	}

	log stdout {
		output stdout
		format console
	}

	root * /app/public

	encode zstd br gzip

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	@static path /build/*
	header @static Cache-Control "public, max-age=31536000, immutable"

	@favicon path /favicon.ico /robots.txt
	header @favicon Cache-Control "public, max-age=86400"

	handle /grafana* {
		reverse_proxy {$GRAFANA_HOST:grafana:3000}
	}

	php_server
}

