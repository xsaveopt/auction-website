{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.14.0",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "typecheck": "vue-tsc --noEmit",
        "lint": "oxlint resources/js/",
        "format": "oxfmt resources/js/",
        "format:check": "oxfmt --check resources/js/",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.3.3",
        "@types/node": "^26.1.1",
        "@vue/test-utils": "^2.4.11",
        "@vue/tsconfig": "^0.9.1",
        "axios": "^1.18.1",
        "concurrently": "^10.0.3",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1.3",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "tailwindcss": "^4.3.3",
        "typescript": "^5.9.3",
        "vite": "^8.1.5",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "@vitejs/plugin-vue": "^6.0.8",
        "vue": "^3.5.40",
        "vue-router": "^5.2.0"
    }
}
