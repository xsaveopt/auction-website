APP_DEBUG=true
APP_ENV=local
APP_KEY=
APP_NAME=Laravel
APP_URL=http://localhost
BCRYPT_ROUNDS=12
CACHE_STORE=database
DB_CONNECTION=sqlite
FILESYSTEM_DISK=local
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_STACK=single
QUEUE_CONNECTION=database
SESSION_DOMAIN=null
SESSION_DRIVER=database
SESSION_ENCRYPT=false
SESSION_LIFETIME=120
SESSION_PATH=/
VITE_APP_NAME="${APP_NAME}"

# bidding times
BIDDING_CLOSED_END=18:00
BIDDING_CLOSED_START=09:00
BIDDING_WEEKENDS_OPEN=true

# company info for auto quote pdf
COMPANY_BTW=
COMPANY_CITY=
COMPANY_IBAN_1=
COMPANY_IBAN_2=
COMPANY_KVK=
COMPANY_NAME=
COMPANY_POSTAL_CODE=
COMPANY_STREET=
INVOICE_BTW_PERCENTAGE=21
INVOICE_PAYMENT_DAYS=30
CURRENCY_SYMBOL=€

# MCP API key for AI pricing tools (optional)
MCP_API_KEY=

# microsoft saml details, optional
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"
MICROSOFT_TENANT_ID=