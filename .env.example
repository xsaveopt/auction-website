# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# The name of your application, used in emails and notifications.
APP_NAME="Auction Website"

# The environment your application is running in (local, production, etc.).
# Note: APP_KEY is automatically generated by the Docker container if not provided.
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
SERVER_NAME=localhost

# -----------------------------------------------------------------------------
# Database & Storage
# -----------------------------------------------------------------------------

# SQLite is the default connection. DB_DATABASE is handled automatically in Docker.
DB_CONNECTION=sqlite

# Cache and session storage. Defaults to Redis (requires a Redis server).
# Use "file" for standalone Docker without Redis.
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=database

# Redis connection.
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Auction & Bidding Rules
# -----------------------------------------------------------------------------

# Enable or disable the bidding schedule. When false, bidding is always open.
BIDDING_SCHEDULE_ENABLED=true

# Times when bidding is CLOSED (e.g. 09:00 - 18:00). Format: HH:MM
BIDDING_CLOSED_START=09:00
BIDDING_CLOSED_END=18:00

# Whether bidding is allowed on weekends.
BIDDING_WEEKENDS_OPEN=true

# Currency symbol used for all prices and bids.
CURRENCY_SYMBOL=€

# -----------------------------------------------------------------------------
# Company Information (for Quote PDF generation)
# -----------------------------------------------------------------------------

COMPANY_BTW=
COMPANY_CITY=
COMPANY_IBAN_1=
COMPANY_IBAN_2=
COMPANY_KVK=
COMPANY_NAME=
COMPANY_POSTAL_CODE=
COMPANY_STREET=

# Standard tax and payment terms.
INVOICE_BTW_PERCENTAGE=21
INVOICE_PAYMENT_DAYS=30

# -----------------------------------------------------------------------------
# External Integrations (Optional)
# -----------------------------------------------------------------------------

# MCP API key for AI-driven pricing tools.
MCP_API_KEY=

# Microsoft SSO (Socialite) configuration.
# Used for authentication via Microsoft Entra ID (formerly Azure AD).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"
MICROSOFT_TENANT_ID=

# -----------------------------------------------------------------------------
# Monitoring (docker-compose only)
# -----------------------------------------------------------------------------

# Bearer token for the /metrics endpoint. Shared with Prometheus via docker-compose.
METRICS_TOKEN=

# Grafana admin credentials.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Grafana sub-path configuration.
GF_SERVER_ROOT_URL=http://localhost/grafana
GF_SERVER_SERVE_FROM_SUB_PATH=true

# -----------------------------------------------------------------------------
# Logs & Maintenance
# -----------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_LEVEL=debug
