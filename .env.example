# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# The name of your application, used in emails and notifications.
APP_NAME="Auction Website"

# The environment your application is running in (local, production, etc.).
# Note: APP_KEY is automatically generated by the Docker container if not provided.
APP_TIMEZONE=Europe/Amsterdam
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
SERVER_NAME=localhost

# -----------------------------------------------------------------------------
# Database & Storage
# -----------------------------------------------------------------------------

# SQLite is the default connection. In Docker, set DB_DATABASE=/data/database.sqlite.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Cache and session storage. Defaults to Redis (requires a Redis server).
# Use "file" for standalone Docker without Redis.
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=database

# Redis connection.
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Auction & Bidding Rules
# -----------------------------------------------------------------------------

# Enable or disable the bidding schedule. When false, bidding is always open.
BIDDING_SCHEDULE_ENABLED=true

# Times when bidding is CLOSED (e.g. 09:00 - 18:00). Format: HH:MM
BIDDING_CLOSED_START=09:00
BIDDING_CLOSED_END=18:00

# Whether bidding is allowed on weekends.
BIDDING_WEEKENDS_OPEN=true

# Currency symbol used for all prices and bids.
CURRENCY_SYMBOL=€

# Anti-sniping protection. Extends auction end time when bids are placed near the deadline.
ANTI_SNIPING_ENABLED=true
# How many seconds before auction end a bid triggers the extension.
ANTI_SNIPING_WINDOW=60
# How many seconds to add to the auction end time when triggered.
ANTI_SNIPING_EXTENSION=300

# Leftover sales: allow first-come first-served purchases after an auction ends
# when items were not fully allocated. Set LEFTOVER_PRICE_FACTOR to control the
# discount (0.75 = 75% of the original starting price).
LEFTOVER_SALES_ENABLED=false
LEFTOVER_PRICE_FACTOR=0.75

# -----------------------------------------------------------------------------
# Company Information (for Quote PDF generation)
# -----------------------------------------------------------------------------

COMPANY_BTW=
COMPANY_CITY=
COMPANY_IBAN_1=
COMPANY_IBAN_2=
COMPANY_KVK=
COMPANY_NAME=
COMPANY_POSTAL_CODE=
COMPANY_STREET=

# Standard tax and payment terms.
INVOICE_BTW_PERCENTAGE=21
INVOICE_PAYMENT_DAYS=30

# -----------------------------------------------------------------------------
# External Integrations (Optional)
# -----------------------------------------------------------------------------

# MCP API key for AI-driven pricing tools.
MCP_API_KEY=

# Microsoft SSO (Socialite) configuration.
# Used for authentication via Microsoft Entra ID (formerly Azure AD).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"
MICROSOFT_TENANT_ID=

# Browser push notifications (VAPID). Generate a key pair with:
# php artisan app:generate-vapid-keys
# The subject must be a mailto: address or a URL.
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Monitoring (docker-compose only)
# -----------------------------------------------------------------------------

# Bearer token for the /metrics endpoint. Shared with Prometheus via docker-compose.
METRICS_TOKEN=

# Grafana admin credentials.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Grafana sub-path configuration.
GF_SERVER_ROOT_URL=http://localhost/grafana
GF_SERVER_SERVE_FROM_SUB_PATH=true

# -----------------------------------------------------------------------------
# Server / Octane
# -----------------------------------------------------------------------------

# Octane server driver.
OCTANE_SERVER=frankenphp

# -----------------------------------------------------------------------------
# Logs & Maintenance
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
